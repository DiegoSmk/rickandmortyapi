{
  "name": "rick-morty-tournament-api",
  "version": "0.1.0",
  "private": true,
  "description": "API propria para catalogo, sincronizacao, enriquecimento e torneio de Rick and Morty.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "start:prod": "node dist/db/run-migrations.js && node dist/server.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "migrate": "tsx src/db/run-migrations.ts",
    "bootstrap:public-api": "tsx src/jobs/bootstrap-public-api.ts",
    "bootstrap:character-images": "tsx src/jobs/bootstrap-character-images.ts",
    "enrich:all": "tsx src/jobs/enrich-all-characters.ts"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "fastify": "^5.2.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
